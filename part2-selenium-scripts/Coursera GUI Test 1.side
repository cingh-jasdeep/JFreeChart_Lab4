{
  "id": "8ac72380-3044-4198-8f3b-9cbfbbd0c46a",
  "version": "2.0",
  "name": "Coursera GUI Test 1",
  "url": "https://www.coursera.org/",
  "tests": [{
    "id": "d104c4cf-b919-4715-a3df-a98140754c22",
    "name": "TC1: Course Search with array of search terms",
    "commands": [{
      "id": "35fe3861-e2c1-4599-a51e-01ccfa4d3acd",
      "comment": "",
      "command": "executeScript",
      "target": "return [\"engineering\", \"geography\"]",
      "targets": [],
      "value": "searchTerms"
    }, {
      "id": "d677ac58-c277-419d-87d3-b3580dfd5bb2",
      "comment": "",
      "command": "forEach",
      "target": "searchTerms",
      "targets": [],
      "value": "currSearchTerm"
    }, {
      "id": "4598441b-b967-4db3-b8eb-d6becccd86ad",
      "comment": "",
      "command": "open",
      "target": "/",
      "targets": [],
      "value": ""
    }, {
      "id": "621a2a15-6e98-4aad-bb4f-00e6cf3c0eef",
      "comment": "",
      "command": "setWindowSize",
      "target": "1512x949",
      "targets": [],
      "value": ""
    }, {
      "id": "963f1d0f-55f0-4120-ae72-7a21b8a767bb",
      "comment": "",
      "command": "type",
      "target": "id=search-autocomplete-input",
      "targets": [
        ["id=search-autocomplete-input", "id"],
        ["name=query", "name"],
        ["css=#search-autocomplete-input", "css:finder"],
        ["xpath=//input[@id='search-autocomplete-input']", "xpath:attributes"],
        ["xpath=//div[@id='rendered-content']/div/span/span/div/nav/div[2]/div/div/div/div[2]/div/div/form/div/div[2]/div[2]/input", "xpath:idRelative"],
        ["xpath=//input", "xpath:position"]
      ],
      "value": "${currSearchTerm}"
    }, {
      "id": "704b0299-d2a4-43e4-9169-b29883abbdfe",
      "comment": "",
      "command": "click",
      "target": "css=.cds-iconButton-small",
      "targets": [
        ["css=.cds-iconButton-small", "css:finder"],
        ["xpath=//button[@type='submit']", "xpath:attributes"],
        ["xpath=//div[@id='rendered-content']/div/span/span/div/nav/div[2]/div/div/div/div[2]/div/div/form/div/div/div[2]/div[2]/div/button", "xpath:idRelative"],
        ["xpath=//div[2]/div[2]/div/button", "xpath:position"]
      ],
      "value": ""
    }, {
      "id": "f8331022-035d-4a7d-a5e7-8561c97f79a8",
      "comment": "",
      "command": "assertText",
      "target": "xpath=//div[@id='search-results-header-wrapper']/div/div/h2/div/span",
      "targets": [
        ["css=.css-zh12ej span", "css:finder"],
        ["xpath=//div[@id='search-results-header-wrapper']/div/div/h2/div/span", "xpath:idRelative"],
        ["xpath=//h2/div/span", "xpath:position"],
        ["xpath=//span[contains(.,'Results for \"engineering\"')]", "xpath:innerText"]
      ],
      "value": "Results for \"${currSearchTerm}\""
    }, {
      "id": "694b7986-8d32-428b-8c65-d0ac358d9b2e",
      "comment": "",
      "command": "end",
      "target": "",
      "targets": [],
      "value": ""
    }]
  }],
  "suites": [{
    "id": "c863094b-63be-49b9-9fc2-bd43daf1af21",
    "name": "Course Search",
    "persistSession": false,
    "parallel": false,
    "timeout": 300,
    "tests": ["d104c4cf-b919-4715-a3df-a98140754c22"]
  }],
  "urls": ["https://www.coursera.org/"],
  "plugins": []
}